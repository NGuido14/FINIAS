# FINIAS Environment Configuration
# Copy to .env and fill in your API keys:  cp .env.example .env

# Database (matches docker-compose.yml defaults)
FINIAS_POSTGRES_HOST=localhost
FINIAS_POSTGRES_PORT=5434
FINIAS_POSTGRES_DB=finias_agency
FINIAS_POSTGRES_USER=finias_agency
FINIAS_POSTGRES_PASSWORD=finias

# Redis
FINIAS_REDIS_HOST=localhost
FINIAS_REDIS_PORT=6379

# API Keys (required)
FINIAS_ANTHROPIC_API_KEY=your-anthropic-api-key-here
FINIAS_POLYGON_API_KEY=your-polygon-api-key-here
FINIAS_POLYGON_RATE_LIMIT=1000
FINIAS_FRED_API_KEY=your-fred-api-key-here

# Claude Models
FINIAS_CLAUDE_MODEL=claude-opus-4-20250514
FINIAS_CLAUDE_MODEL_FAST=claude-sonnet-4-20250514
FINIAS_CLAUDE_MAX_TOKENS=4096

# System
FINIAS_LOG_LEVEL=INFO
FINIAS_ENVIRONMENT=development
